{
  "name": "costaatt-admissions-letter-automation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 6001",
    "start:6001": "next start -H 0.0.0.0 -p 6001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "validate": "npm run lint && npm run typecheck && npm test && npm run build && npm audit --omit=dev",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs db/migrations/001_initial_schema.sql db/migrations/002_operational_integrity.sql db/migrations/003_app_settings.sql db/migrations/004_query_performance.sql db/migrations/005_field_mapping_integrity.sql db/migrations/006_operational_status_consistency.sql db/migrations/007_template_type_integrity.sql db/migrations/008_storage_key_integrity.sql db/migrations/009_applicant_duplicate_send_integrity.sql db/migrations/010_applicant_status_consistency.sql db/migrations/011_template_name_integrity.sql db/migrations/012_field_mapping_fallback_integrity.sql db/migrations/013_upload_filename_integrity.sql db/migrations/014_app_settings_integrity.sql db/migrations/015_jsonb_array_integrity.sql db/migrations/016_sender_and_archiving.sql db/migrations/017_template_email_content.sql",
    "db:seed": "node --env-file-if-exists=.env.local scripts/migrate.mjs db/seeds/001_template_types.sql",
    "templates:install": "node --env-file-if-exists=.env.local scripts/install-bundled-templates.mjs",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run templates:install",
    "smoke": "node --env-file-if-exists=.env.local scripts/smoke.mjs"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.17.0",
    "archiver": "^7.0.1",
    "docxtemplater": "^3.62.0",
    "exceljs": "^4.4.0",
    "jose": "^5.10.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.20",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "pizzip": "^3.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^7.0.12",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "postcss": "^8.5.19",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.19",
    "uuid": "^11.1.1"
  }
}
